{
	"name": "@nucel/ui",
	"version": "0.16.0",
	"description": "A comprehensive Svelte 5 UI component library for Nucel projects",
	"type": "module",
	"svelte": "./src/lib/index.ts",
	"sideEffects": [
		"*.css",
		"**/*.svelte"
	],
	"exports": {
		".": {
			"types": "./src/lib/index.ts",
			"svelte": "./src/lib/index.ts",
			"default": "./src/lib/index.ts"
		},
		"./monaco": {
			"types": "./src/lib/monaco.ts",
			"svelte": "./src/lib/monaco.ts",
			"default": "./src/lib/monaco.ts"
		},
		"./editor": {
			"types": "./src/lib/editor.ts",
			"svelte": "./src/lib/editor.ts",
			"default": "./src/lib/editor.ts"
		},
		"./styles.css": "./src/styles.css"
	},
	"files": [
		"src/lib",
		"!src/**/*.test.ts",
		"!src/**/*.spec.ts",
		"!src/tests",
		"src/styles.css"
	],
	"scripts": {
		"dev": "vite",
		"build": "vite build",
		"check": "svelte-check --tsconfig ./tsconfig.json",
		"lint": "eslint .",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"test": "vitest run",
		"test:watch": "vitest",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build",
		"prepublishOnly": "echo 'publishing @nucel/ui'"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/nucel/ui.git"
	},
	"keywords": [
		"svelte",
		"svelte5",
		"ui",
		"components",
		"shadcn",
		"tailwindcss",
		"bits-ui",
		"component-library"
	],
	"author": "Nucel Team",
	"license": "MIT",
	"dependencies": {
		"@internationalized/date": "^3.5.0",
		"@lucide/svelte": "^1.18.0",
		"@number-flow/svelte": "^0.4.0",
		"@tiptap/core": "^3.26.1",
		"@tiptap/extension-character-count": "^3.26.1",
		"@tiptap/extension-color": "^3.26.1",
		"@tiptap/extension-highlight": "^3.26.1",
		"@tiptap/extension-link": "^3.26.1",
		"@tiptap/extension-mention": "^3.26.1",
		"@tiptap/extension-placeholder": "^3.26.1",
		"@tiptap/extension-subscript": "^3.26.1",
		"@tiptap/extension-superscript": "^3.26.1",
		"@tiptap/extension-table": "^3.26.1",
		"@tiptap/extension-table-cell": "^3.26.1",
		"@tiptap/extension-table-header": "^3.26.1",
		"@tiptap/extension-table-row": "^3.26.1",
		"@tiptap/extension-task-item": "^3.26.1",
		"@tiptap/extension-task-list": "^3.26.1",
		"@tiptap/extension-text-align": "^3.26.1",
		"@tiptap/extension-text-style": "^3.26.1",
		"@tiptap/extension-typography": "^3.26.1",
		"@tiptap/extension-underline": "^3.26.1",
		"@tiptap/starter-kit": "^3.26.1",
		"bits-ui": "^2.18.1",
		"clsx": "^2.1.1",
		"dompurify": "^3.4.10",
		"marked": "^18.0.5",
		"shiki": "^4.2.0",
		"svelte-sonner": "^1.1.1",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2",
		"tippy.js": "^6.3.7"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@storybook/addon-a11y": "^10.4.4",
		"@storybook/addon-docs": "^10.4.4",
		"@storybook/addon-svelte-csf": "^5.0.0",
		"@storybook/addon-vitest": "^10.4.4",
		"@storybook/svelte-vite": "^10.4.4",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.3.1",
		"@types/dompurify": "^3.2.0",
		"@vitest/browser": "^4.1.8",
		"@vitest/browser-playwright": "^4.1.8",
		"eslint": "^10.5.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"jsdom": "^29.1.1",
		"monaco-editor": "^0.55.1",
		"playwright": "^1.60.0",
		"prettier": "^3.8.4",
		"prettier-plugin-svelte": "^4.1.0",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"storybook": "^10.4.4",
		"svelte": "^5.56.3",
		"svelte-check": "^4.6.0",
		"tailwindcss": "^4.3.1",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.61.0",
		"vite": "^8.0.16",
		"vitest": "^4.1.8"
	},
	"peerDependencies": {
		"svelte": "^5.0.0",
		"tailwindcss": "^4.0.0",
		"monaco-editor": "^0.52.0 || ^0.55.0"
	},
	"peerDependenciesMeta": {
		"monaco-editor": {
			"optional": true
		}
	}
}

{
	"name": "@nucel/ui",
	"version": "0.1.0",
	"description": "A comprehensive Svelte 5 UI component library for Nucel projects",
	"type": "module",
	"svelte": "./src/lib/index.ts",
	"exports": {
		".": {
			"types": "./src/lib/index.ts",
			"svelte": "./src/lib/index.ts",
			"default": "./src/lib/index.ts"
		}
	},
	"files": [
		"src/lib",
		"src/styles.css"
	],
	"scripts": {
		"dev": "vite",
		"build": "vite build",
		"check": "svelte-check --tsconfig ./tsconfig.json",
		"lint": "eslint .",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"test": "vitest run",
		"test:watch": "vitest",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build",
		"prepublishOnly": "echo 'publishing @nucel/ui'"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/nucel/ui.git"
	},
	"keywords": [
		"svelte",
		"svelte5",
		"ui",
		"components",
		"shadcn",
		"tailwindcss",
		"bits-ui",
		"component-library"
	],
	"author": "Nucel Team",
	"license": "MIT",
	"dependencies": {
		"@lucide/svelte": "^0.564.0",
		"bits-ui": "^2.16.1",
		"clsx": "^2.1.1",
		"dompurify": "^3.3.3",
		"marked": "^17.0.5",
		"svelte-sonner": "^1.0.7",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.2",
		"@storybook/addon-a11y": "^10.0.0",
		"@storybook/addon-docs": "^10.0.0",
		"@storybook/addon-svelte-csf": "^5.0.0",
		"@storybook/addon-vitest": "^10.0.0",
		"@storybook/svelte-vite": "^10.3.4",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.1.18",
		"@types/dompurify": "^3.2.0",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.14.0",
		"globals": "^17.3.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"storybook": "^10.0.0",
		"svelte": "^5.49.2",
		"svelte-check": "^4.3.6",
		"tailwindcss": "^4.1.18",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.8.0",
		"typescript-eslint": "^8.54.0",
		"vite": "^8.0.0",
		"vitest": "^4.0.18"
	},
	"peerDependencies": {
		"svelte": "^5.0.0",
		"tailwindcss": "^4.0.0"
	}
}
